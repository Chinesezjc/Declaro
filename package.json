{
  "name": "declaro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:runtime && tsx src/server/index.ts",
    "build": "npm run build:runtime && tsc --noEmit && tsx src/server/index.ts",
    "build:static": "npm run build:runtime && tsx src/compiler/compile.ts --output",
    "build:runtime": "tsx scripts/build-runtime.ts",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "declaro": "./bin/declaro.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "package.json",
    "tsconfig.json"
  ],
  "dependencies": {
    "@types/express": "^5.0.6",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "katex": "^0.16.11",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "4.2.1",
    "tsx": "^4.22.4",
    "typescript": "5.4.5",
    "vite": "5.2.14"
  }
}
